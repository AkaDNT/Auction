{
  "name": "auction",
  "private": true,
  "version": "1.0.0",
  "packageManager": "npm@11.6.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:migrate": "npm -w @repo/db run prisma:migrate",
    "db:generate": "npm -w @repo/db run prisma:generate",
    "db:studio": "npm -w @repo/db run prisma:studio"
  },
  "devDependencies": {
    "turbo": "^2.9.4"
  }
}
